# Firebase 클라이언트 (브라우저) — miokbook 프로젝트
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCoP0ykA_RGIQuF1K1b7Z3yV9pmqXInfjs
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=miokbook-4c24a.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=miokbook-4c24a
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=miokbook-4c24a.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=221726075811
NEXT_PUBLIC_FIREBASE_APP_ID=1:221726075811:web:3e2f11f7f6120d94570816

# Firebase Admin (서버/API 전용) — 서비스 계정 키에서 복사
# Firebase Console > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성 → JSON 다운로드
# JSON 안의 "client_email", "private_key" 값을 아래에 맞춰 넣으세요.
FIREBASE_ADMIN_PROJECT_ID=miokbook-4c24a
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-fbsvc@miokbook-4c24a.iam.gserviceaccount.com
# private_key: JSON의 "private_key" 전체를 복사 (줄바꿈은 \n 그대로 또는 실제 줄바꿈)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 카카오 로그인 (REST API) — 플랫폼 키 > 해당 REST API 키에 Redirect URI 등록
# KAKAO_REST_API_KEY=
# NEXT_PUBLIC_KAKAO_REST_API_KEY=
# NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback
# REST API 키 상세에서 Client Secret 발급 시 토큰 교환에 필수
# KAKAO_CLIENT_SECRET=
# 비즈니스 인증용 클라이언트 시크릿(해당 기능/API 연동 시)
# KAKAO_BUSINESS_CLIENT_SECRET=

# 선택: 토스 결제, Meilisearch, Upstash 등
# NEXT_PUBLIC_TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=
# TOSS_WEBHOOK_SECRET=
# NEXT_PUBLIC_MEILISEARCH_HOST=
# MEILISEARCH_MASTER_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Vercel 외 배포(AWS 등): 공개 Meilisearch 없을 때 Firestore 검색 폴백으로 reads 폭증 방지
# PROTECT_SEARCH_FIRESTORE_FALLBACK=true
# 또는 Meilisearch 없이 검색 끄기: DISABLE_SEARCH_FIRESTORE_FALLBACK=true
# 목록/검색 API DB 폴백(명시 제어): ALLOW_SEARCH_FIRESTORE_FALLBACK=true|false (미설정 + SUPABASE_SERVICE_ROLE_KEY 있으면 허용)
# 자동완성 DB 폴백: ALLOW_AUTOCOMPLETE_FIRESTORE_FALLBACK=true|false (미설정 + SUPABASE_SERVICE_ROLE_KEY 있으면 허용)

# Cloud Functions(결제 확정·고객 취소) → 스토어 캐시 무효화. Functions에도 동일 키로 설정하세요.
# INTERNAL_REVALIDATE_SECRET=
# STORE_FRONTEND_URL=https://your-production-domain.com

# 선택: 분석
# GA4 — 어떤 호스팅(Vercel/AWS/Cloudflare)에서든 동작. 측정 ID만 설정하면 됨.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Vercel Analytics — Vercel 배포 시에만 의미 있음. AWS/Cloudflare 이전 시 false 또는 제거.
# NEXT_PUBLIC_VERCEL_ANALYTICS=false

# 유캔싸인 전자서명
# UCANSIGN_API_KEY=
# UCANSIGN_WEBHOOK_SECRET=

# 유튜브 콘텐츠 (어드민 영상 피커 — Data API v3)
# YOUTUBE_API_KEY=
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx

# 선택: 검색 fallback (내부 0건 시 알라딘 API 결과 노출)
# ALADIN_TTB_KEY=

# 1:1 고객문의 이메일 전송 (Gmail SMTP)
# Gmail 계정 설정 > 보안 > 2단계 인증 활성화 후 '앱 비밀번호' 생성
# GMAIL_USER=support.miokbook@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Supabase (DB/Auth + 무료 플랜 어드민 이미지 Storage)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# 어드민 업로드(/api/admin/upload): 공개 버킷을 하나 만든 뒤 이름만 넣으면 Firebase Storage 없이 동작
# SUPABASE_STORAGE_BUCKET=cms-public
