# ---------------------------------------------------------------------------
# 예시 파일 — 값은 Firebase / Supabase 콘솔에서 복사. 실제 비밀은 .env.local 에만 두세요.
# 공개 저장소에 진짜 키를 커밋하지 마세요.
# ---------------------------------------------------------------------------

# Supabase (도서 목록·검색·서버 API — Vercel 배포 시 필수)
# Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Firebase 클라이언트 (브라우저) — Firebase Console > 프로젝트 설정 > 일반 > 내 앱
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id

# Firebase Admin (서버 전용 — 업로드·토큰 검증. Vercel에서 미설정 시 Storage 업로드 503)
# Firebase Console > 프로젝트 설정 > 서비스 계정 > 새 비공개 키
# Vercel: private_key 줄바꿈 깨짐 방지용으로 아래 JSON 한 줄 변수가 더 안전할 수 있음
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# 선택: 서버 업로드 전용 버킷 (미설정 시 NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET 사용)
# FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 사이트 URL (sitemap·메타 등)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# 카카오 로그인 (REST API) — 플랫폼 키 > 해당 REST API 키에 Redirect URI 등록
# KAKAO_REST_API_KEY=
# NEXT_PUBLIC_KAKAO_REST_API_KEY=
# NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback
# KAKAO_CLIENT_SECRET=
# KAKAO_BUSINESS_CLIENT_SECRET=

# 선택: 토스 결제, Meilisearch, Upstash 등
# NEXT_PUBLIC_TOSS_CLIENT_KEY=
# TOSS_SECRET_KEY=
# TOSS_WEBHOOK_SECRET=
# NEXT_PUBLIC_MEILISEARCH_HOST=
# NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=
# MEILISEARCH_MASTER_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# PROTECT_SEARCH_FIRESTORE_FALLBACK=true
# DISABLE_SEARCH_FIRESTORE_FALLBACK=true

# Cloud Functions(결제 확정·고객 취소) → 스토어 캐시 무효화
# INTERNAL_REVALIDATE_SECRET=
# STORE_FRONTEND_URL=https://your-production-domain.com

# 선택: 분석
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_VERCEL_ANALYTICS=false

# 유튜브 콘텐츠 (어드민)
# YOUTUBE_API_KEY=
# YOUTUBE_CHANNEL_ID=

# 선택: 검색 fallback (내부 0건 시 알라딘 API)
# ALADIN_TTB_KEY=
